        "darwin-x64":   { "url": "https://github.com/BurntSushi/ripgrep/releases/download/14.1.1/ripgrep-14.1.1-x86_64-apple-darwin.tar.gz", "archive": "tar.gz", "binPath": "ripgrep-14.1.1-x86_64-apple-darwin/rg", "sha256": "fc87e78f7cb3fea12d69072e7ef3b21509754717b746368fd40d88963630e2b3" }
