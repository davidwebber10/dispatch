        "darwin-x64":   { "url": "https://github.com/DopplerHQ/cli/releases/download/3.76.0/doppler_3.76.0_macOS_amd64.tar.gz", "archive": "tar.gz", "binPath": "doppler", "sha256": "1a70842d5de95232c5bae732721058690c748db5e5c7510e828116392e9f0682" }
      },
      "docs": "https://docs.doppler.com/docs/cli"
    },
    {
      "name": "databricks",
      "description": "Databricks CLI",
      "kind": "binary",
      "bins": ["databricks"],
      "authEnv": ["DATABRICKS_HOST", "DATABRICKS_TOKEN"],
      "binary": {
        "darwin-arm64": { "url": "https://github.com/databricks/cli/releases/download/v1.5.0/databricks_cli_1.5.0_darwin_arm64.tar.gz", "archive": "tar.gz", "binPath": "databricks", "sha256": "41ccc456d609f628413b231c467bb53fb066ecab2e96df492a4df98361e5f001" },
