#!/usr/bin/env bash
#
# dispatch — control the Dispatch daemon (macOS / launchd).
#
#   dispatch build       Install dependencies and build the server + web client
#   dispatch install     Build (if needed) and install + start the launchd daemon
#   dispatch uninstall   Stop and remove the launchd daemon
#   dispatch start        Start the daemon
#   dispatch stop         Stop the daemon
#   dispatch restart      Restart the daemon
#   dispatch status       Show daemon + HTTP health status
#   dispatch logs [-f]    Show (or follow) the daemon logs
#   dispatch update       git pull, rebuild, and restart
#   dispatch run          Run the server in the foreground (no daemon)
#
set -uo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LABEL="com.dispatch.server"
# Over SSH you can't bootstrap into the GUI (Aqua) domain — it fails with an I/O
# error — so fall back to the per-user domain, which works headless.
if [ -n "${SSH_CONNECTION:-}" ]; then DOMAIN="user/$(id -u)"; else DOMAIN="gui/$(id -u)"; fi
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
TEMPLATE="$REPO/daemon/com.dispatch.server.plist.template"
LOGDIR="$HOME/Library/Logs/dispatch"
STDOUT="$LOGDIR/dispatch.out.log"
STDERR="$LOGDIR/dispatch.err.log"
SERVER_JS="$REPO/packages/core/dist/server.js"
WEBDIST="$REPO/packages/web/dist"
PORT="${PORT:-3456}"

bold() { printf '\033[1m%s\033[0m\n' "$1"; }
green() { printf '\033[32m%s\033[0m\n' "$1"; }
red() { printf '\033[31m%s\033[0m\n' "$1" >&2; }
info() { printf '  %s\n' "$1"; }

require_node() {
  if ! command -v node >/dev/null 2>&1; then
    red "Node.js not found on PATH. Install Node 18+ (https://nodejs.org) and retry."
    exit 1
  fi
}

require_pnpm() {
  if ! command -v pnpm >/dev/null 2>&1; then
    red "pnpm not found. Install it with:  npm install -g pnpm   (or  corepack enable)"
    exit 1
  fi
}

cmd_build() {
  require_node; require_pnpm
  bold "Installing dependencies…"
  ( cd "$REPO" && CI=true pnpm install ) || { red "pnpm install failed"; exit 1; }
  bold "Building server + web client…"
  ( cd "$REPO" && pnpm -r run build ) || { red "build failed"; exit 1; }
  green "Build complete."
}

ensure_built() {
  if [ ! -f "$SERVER_JS" ] || [ ! -f "$WEBDIST/index.html" ]; then
    info "Build output missing — building first."
    cmd_build
  fi
}

write_plist() {
  require_node
  local node_bin node_dir path_val
  node_bin="$(command -v node)"
  node_dir="$(dirname "$node_bin")"
  path_val="$node_dir:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/.local/bin"
  mkdir -p "$LOGDIR" "$(dirname "$PLIST")"
  sed \
    -e "s#__LABEL__#$LABEL#g" \
    -e "s#__NODE__#$node_bin#g" \
    -e "s#__SERVER_JS__#$SERVER_JS#g" \
    -e "s#__WORKDIR__#$REPO#g" \
    -e "s#__PATH__#$path_val#g" \
    -e "s#__PORT__#$PORT#g" \
    -e "s#__WEBDIST__#$WEBDIST#g" \
    -e "s#__STDOUT__#$STDOUT#g" \
    -e "s#__STDERR__#$STDERR#g" \
    "$TEMPLATE" > "$PLIST"
}

# launchd helpers — prefer the modern API (works inside a GUI session); fall back to
# the legacy load/unload, which is what works over SSH (bootstrap returns EIO there).
is_loaded() { launchctl list 2>/dev/null | grep -q "$LABEL"; }
agent_pid() { launchctl list 2>/dev/null | awk -v l="$LABEL" '$3==l{print $1}'; }
load_agent() {
  if launchctl bootstrap "$DOMAIN" "$PLIST" 2>/dev/null; then
    launchctl enable "$DOMAIN/$LABEL" 2>/dev/null || true
  else
    launchctl load -w "$PLIST" 2>/dev/null || true
  fi
  is_loaded
}
unload_agent() { launchctl bootout "$DOMAIN/$LABEL" 2>/dev/null || launchctl unload -w "$PLIST" 2>/dev/null || true; }

cmd_install() {
  ensure_built
  bold "Installing launchd daemon ($LABEL)…"
  write_plist
  unload_agent
  load_agent || { red "failed to load the launchd agent"; exit 1; }
  green "Installed and started."
  info "Local URL:  http://localhost:$PORT"
  info "Logs:       $STDOUT"
  info "Next:       expose it publicly — see docs/cloudflare.md"
}

cmd_uninstall() {
  bold "Removing launchd daemon…"
  unload_agent
  rm -f "$PLIST"
  green "Uninstalled. (Your data in ~/.dispatch was left intact.)"
}

cmd_start() { load_agent && green "Started." || { red "Failed to start (run: dispatch install)"; exit 1; }; }
cmd_stop() { unload_agent; green "Stopped."; }
cmd_restart() { unload_agent; load_agent && green "Restarted." || { red "Failed to restart"; exit 1; }; }

cmd_status() {
  bold "Daemon"
  if is_loaded; then
    info "loaded   yes"
    info "pid      $(agent_pid)"
  else
    info "loaded   no   (run: dispatch install)"
  fi
  bold "HTTP"
  if curl -fsS -m 3 "http://localhost:$PORT/api/sessions" >/dev/null 2>&1; then
    green "  reachable at http://localhost:$PORT"
  else
    red "  not responding on http://localhost:$PORT"
  fi
}

cmd_logs() {
  mkdir -p "$LOGDIR"; touch "$STDOUT" "$STDERR"
  if [ "${1:-}" = "-f" ]; then tail -f "$STDOUT" "$STDERR"; else tail -n 200 "$STDOUT" "$STDERR"; fi
}

cmd_update() {
  bold "Updating…"
  ( cd "$REPO" && git pull --ff-only ) || { red "git pull failed"; exit 1; }
  cmd_build
  cmd_restart
}

cmd_run() {
  ensure_built
  require_node
  bold "Running Dispatch in the foreground (Ctrl-C to stop) on port $PORT…"
  PORT="$PORT" DISPATCH_WEB_DIST="$WEBDIST" exec node "$SERVER_JS"
}

usage() {
  cat <<'EOF'
dispatch — control the Dispatch daemon (macOS / launchd).

  dispatch build       Install dependencies and build the server + web client
  dispatch install     Build (if needed) and install + start the launchd daemon
  dispatch uninstall   Stop and remove the launchd daemon
  dispatch start       Start the daemon
  dispatch stop        Stop the daemon
  dispatch restart     Restart the daemon
  dispatch status      Show daemon + HTTP health status
  dispatch logs [-f]   Show (or follow) the daemon logs
  dispatch update      git pull, rebuild, and restart
  dispatch run         Run the server in the foreground (no daemon)
EOF
}

case "${1:-}" in
  build)     cmd_build ;;
  install)   cmd_install ;;
  uninstall) cmd_uninstall ;;
  start)     cmd_start ;;
  stop)      cmd_stop ;;
  restart)   cmd_restart ;;
  status)    cmd_status ;;
  logs)      shift; cmd_logs "${1:-}" ;;
  update)    cmd_update ;;
  run)       cmd_run ;;
  ""|help|-h|--help) usage ;;
  *) red "Unknown command: $1"; usage; exit 1 ;;
esac
