#!/bin/sh
# Resolve symlinks so a `dispatch` symlink on PATH still finds the repo.
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  dir="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$dir/$SOURCE" ;; esac
done
DIR="$(cd "$(dirname "$SOURCE")/.." && pwd)"
exec node "$DIR/packages/cli/dist/index.js" "$@"
