{
  "name": "dispatch",
  "version": "1.0.0",
  "private": true,
  "description": "Control your coding agents (Claude Code, Codex) and terminals from any browser or phone.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "dev:server": "pnpm --filter dispatch-server dev",
    "dev:web": "pnpm --filter dispatch-web dev",
    "start": "node packages/core/dist/server.js",
    "postinstall": "node scripts/fix-node-pty-perms.mjs"
  },
  "bin": {
    "dispatch": "packages/cli/dist/index.js"
  },
  "engines": {
    "node": ">=18"
  }
}
